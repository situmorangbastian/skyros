# ── deps: download modules separately so this layer is cached
#         as long as go.mod / go.sum don't change
FROM golang:1.26.1-alpine AS deps

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download && go mod verify

# ── build: compile the binary
FROM deps AS build

COPY ./userservice  ./userservice
COPY ./proto        ./proto
COPY ./serviceutils ./serviceutils

RUN CGO_ENABLED=0 GOOS=linux go build \
    -ldflags="-s -w" \
    -trimpath \
    -o /out/skyros-user-service \
    github.com/situmorangbastian/skyros/userservice

# ── final: minimal distroless image
FROM gcr.io/distroless/static:nonroot

COPY --from=build /out/skyros-user-service      /skyros-user-service
COPY --from=build /build/userservice/migrations /migrations

EXPOSE 4011

USER nonroot:nonroot

ENTRYPOINT ["/skyros-user-service"]
